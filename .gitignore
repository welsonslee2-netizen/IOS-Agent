*.p8
AuthKey*.p8
api_key.json

# 环境变量
.env
.env.local
*.env

# 临时文件
tmp/
temp/
*.tmp
*.log

# WorkBuddy 工作记忆（仅本地使用）
.workbuddy/

# 辅助脚本
*.bat
setup*.bat
